# Environment variable template.
# Copy to `.env` (gitignored) and fill in real values locally.
# Never commit real secrets.
#
# GROQ_API_KEY: chiave API Groq, richiesta per la generazione del piano
# pasti via AI (endpoint /meal-plan/auto-distribute e /meal-plan/auto-plan).
# Ottienila su https://console.groq.com/keys
GROQ_API_KEY=
#
# GROQ_MODEL: modello Groq da usare (opzionale).
# GROQ_MODEL=llama-3.3-70b-versatile
#
# FAMILY_PROFILE: descrizione libera (età, allergie, obiettivi nutrizionali)
# usata nel prompt di auto-distribuzione del piano pasti. Lasciare non
# impostata per un piano generico senza vincoli personali.
# FAMILY_PROFILE=Adulto 1: nessun vincolo. Bambino 1 (5 anni): nessuna allergia nota.
